# Copy to terraform.tfvars and fill in values before running terraform apply
# DO NOT commit terraform.tfvars to version control

aws_region  = "us-east-1"
environment = "production"
project     = "sri"

# Networking
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b", "us-east-1c"]

# Database
db_instance_class = "db.t3.medium"   # db.t3.large for higher load
db_name           = "sriplatform"
db_username       = "sriplatform"

# Redis
redis_node_type = "cache.t3.medium"

# Kafka
kafka_version              = "3.5.1"
kafka_broker_instance_type = "kafka.m5.large"
kafka_broker_count         = 3

# OpenSearch
opensearch_version       = "OpenSearch_2.11"
opensearch_instance_type = "r6g.large.search"

# MWAA Airflow
airflow_version           = "2.8.1"
airflow_environment_class = "mw1.small"   # mw1.medium for higher throughput

# Route 53 / domain
domain_name = "sriplatform.com"   # change to your domain

# GitHub
github_org = "motorhead2840"

# AWS Outposts (leave empty until Outpost rack is delivered by AWS)
outpost_arn              = ""
outpost_local_gateway_id = ""
